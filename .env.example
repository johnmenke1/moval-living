# =============================================================================
# MovaL Living — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (it's already in .gitignore).
# NEVER paste real secrets into chat, PRs, or screenshots.
# =============================================================================

# --- Database ---------------------------------------------------------------
# Neon Postgres connection string.
# Get it from: https://console.neon.tech → your project → Connection Details
# Local dev: the "Pooled" connection string is fine.
DATABASE_URL=

# --- Google Maps ------------------------------------------------------------
# Public browser key for the Maps JavaScript API.
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
# Restrictions to set on the key:
#   - Application restrictions: HTTP referrers
#     - http://localhost:3000/*
#     - https://moval.living/*
#     - https://*.vercel.app/*
#   - API restrictions: Maps JavaScript API, Places API (if used)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Auth (NextAuth / Auth.js) ---------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the deployed site (used for callback URLs).
AUTH_URL=http://localhost:3000

# --- Email (passwordless login + notifications) ----------------------------
# Pick ONE provider. AWS SES is recommended for production.
# --- Option A: AWS SES ---
SES_REGION=us-east-2
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=hello@moval.living

# --- Option B: Resend (simpler, free tier available) -----------------------
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=hello@moval.living

# --- Marketing backend (GoHighLevel) ---------------------------------------
# Webhook for new leads / claims / submissions.
# Create a workflow trigger in GHL, paste the inbound webhook URL here.
GOHIGHLEVEL_WEBHOOK_URL=
