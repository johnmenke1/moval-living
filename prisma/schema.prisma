// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  tagline          String?
  description      String    @db.Text
  categoryId       String
  category         Category  @relation(fields: [categoryId], references: [id])
  tier             Tier      @default(FREE)
  status           Status    @default(PENDING)

  // Contact
  email            String?
  phone            String?
  website          String?
  address          String
  city             String    @default("Moreno Valley")
  state            String    @default("CA")
  zip              String
  latitude         Float?
  longitude        Float?

  // Media
  logo             String?
  coverImage       String?
  photos           String[]  // Array of photo URLs

  // Social
  facebook         String?
  instagram        String?
  yelp             String?
  googleBusiness   String?

  // Hours stored as JSON: { mon: { open: "9:00 AM", close: "5:00 PM", closed: false }, ... }
  hours            Json?

  // SEO
  metaTitle        String?
  metaDescription  String?

  // Coupon/Deal
  hasCoupon        Boolean   @default(false)
  coupon          Json?     // { headline: string, description: string, code?: string, expiresAt?: string }

  // Relations
  owner           Owner?     @relation(fields: [ownerId], references: [id])
  ownerId         String?    @unique
  claimToken      String?    @unique  // One-time token to claim ownership
  claimExpiresAt  DateTime?            // Token expires after 7 days
  reviews         Review[]
  socialPosts     SocialPost[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([tier])
  @@index([city])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  icon        String     // Lucide icon name e.g. "Utensils", "Car", "Stethoscope"
  image       String?    // Optional category hero image URL
  businesses  Business[]
  createdAt   DateTime   @default(now())

  @@index([slug])
}

model Owner {
  id            String    @id @default(cuid())
  role          UserRole  @default(USER)
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  business      Business?
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token     String? @db.Text
  expires_at       Int?
  token_type       String?
  scope             String?
  id_token         String? @db.Text
  session_state    String?
  owner            Owner   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  owner        Owner    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token     String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

model Review {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String?
  rating      Int       // 1-5
  content     String    @db.Text
  response    String?   @db.Text  // Owner's response
  flagged     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId])
  @@index([flagged])
}

model SocialPost {
  id          String       @id @default(cuid())
  platform    Platform     // INSTAGRAM or FACEBOOK
  postUrl     String
  caption     String?      @db.Text
  mediaUrl    String?      // Primary image/video URL (extracted from post)
  authorName  String?
  authorAvatar String?
  status      PostStatus   @default(PENDING)
  // Optional link to a business (if the event/opportunity is from that business)
  businessId  String?
  business    Business?    @relation(fields: [businessId], references: [id], onDelete: SetNull)
  submittedBy String?      // Owner's email or name
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([businessId])
}

enum Platform {
  INSTAGRAM
  FACEBOOK
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Tier {
  FREE
  FEATURED
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}
